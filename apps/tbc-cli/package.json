{
  "name": "@tbc-frameworx/tbc-cli",
  "version": "0.4.1",
  "description": "TBC CLI application",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tbc": "dist/index.js"
  },
  "scripts": {
    "test": "bun test tests/integration.test.ts",
    "build": "bun build:src && bun build:types",
    "build:src": "bun build src/index.ts --outfile=dist/index.js --target=bun",
    "build:types": "bunx tsc --emitDeclarationOnly --outDir dist",
    "build:exe": "bun build src/index.ts --compile --outfile dist/tbc",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "pocketflow": "^1.0.4",
    "@hami-frameworx/core": "0.1.10",
    "@tbc-frameworx/tbc-record": "^0.4.1",
    "@tbc-frameworx/tbc-record-fs": "^0.4.1",
    "@tbc-frameworx/tbc-record-sqlite": "^0.4.1",
    "@tbc-frameworx/tbc-mint": "^0.4.1",
    "@tbc-frameworx/tbc-synthesize": "^0.4.1",
    "@tbc-frameworx/tbc-system": "^0.4.1",
    "@tbc-frameworx/tbc-interface": "^0.4.1",
    "@tbc-frameworx/tbc-memory": "^0.4.1",
    "@tbc-frameworx/tbc-activity": "^0.4.1",
    "@tbc-frameworx/tbc-kilocode": "^0.4.1",
    "@tbc-frameworx/tbc-goose": "^0.4.1",
    "@tbc-frameworx/tbc-gemini": "^0.4.1",
    "@tbc-frameworx/tbc-github-copilot": "^0.4.1",
    "@tbc-frameworx/tbc-pi": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5.0.0"
  },
  "keywords": [],
  "author": "",
  "types": "./dist/index.d.ts",
  "files": ["dist"]
}