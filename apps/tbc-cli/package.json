{
  "name": "@tbc-frameworx/tbc-cli",
  "version": "0.4.0",
  "description": "TBC CLI application",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tbc": "dist/index.js"
  },
  "scripts": {
    "build": "bun build:src && bun build:types",
    "build:src": "bun build src/index.ts --outfile=dist/index.js --target=bun",
    "build:types": "bunx tsc --emitDeclarationOnly --outDir dist",
    "build:exe": "bun build src/index.ts --compile --outfile dist/tbc",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "pocketflow": "^1.0.4",
    "@hami-frameworx/core": "0.1.4",
    "@tbc-frameworx/tbc-record": "^0.1.0",
    "@tbc-frameworx/tbc-record-fs": "^0.1.0",
    "@tbc-frameworx/tbc-system": "^0.4.0",
    "@tbc-frameworx/tbc-dex": "^0.1.0",
    "@tbc-frameworx/tbc-mint": "^0.1.0",
    "@tbc-frameworx/tbc-mint-uuid": "^0.1.0",
    "@tbc-frameworx/tbc-mint-tsid": "^0.1.0",
    "@tbc-frameworx/tbc-interface": "^0.1.0",
    "@tbc-frameworx/tbc-memory": "^0.1.0",
    "@tbc-frameworx/tbc-activity": "^0.1.0",
    "@tbc-frameworx/tbc-kilocode": "^0.1.0",
    "@tbc-frameworx/tbc-goose": "^0.1.0",
    "@tbc-frameworx/tbc-gemini": "^0.1.0",
    "@tbc-frameworx/tbc-github-copilot": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [],
  "author": "",
  "types": "./dist/index.d.ts",
  "files": ["dist"]
}