{
  "name": "tbc-frameworx-monorepo",
  "version": "0.1.0",
  "description": "Monorepo for TBC FRAMEWORX",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "cli:build": "bun run --filter=\"@tbc-frameworx/tbc-cli\" build",
    "cli:dev": "bun run --cwd apps/tbc-cli dev",
    "cli:install": "bun run --cwd apps/tbc-cli build && cd apps/tbc-cli && bun link",
    "system:build": "bun run --cwd packages/tbc-system build",
    "view:build": "bun run --cwd packages/tbc-view build",
    "record-fs:build": "bun run --cwd packages/tbc-record-fs build",
    "record-sqlite:build": "bun run --cwd packages/tbc-record-sqlite build",
    "generator:build": "bun run --cwd packages/tbc-generator build",
    "interface:build": "bun run --cwd packages/tbc-interface build",
    "memory:build": "bun run --cwd packages/tbc-memory build",
    "activity:build": "bun run --cwd packages/tbc-activity build",
    "gemini:build": "bun run --cwd packages/tbc-gemini build",
    "kilocode:build": "bun run --cwd packages/tbc-kilocode build",
    "goose:build": "bun run --cwd packages/tbc-goose build",
    "github-copilot:build": "bun run --cwd packages/tbc-github-copilot build",
    "all:build": "bun run record-fs:build && bun run record-sqlite:build && bun run generator:build && bun run interface:build && bun run memory:build && bun run activity:build && bun run view:build && bun run system:build && bun run gemini:build && bun run kilocode:build && bun run goose:build && bun run github-copilot:build && bun run --filter=\"@tbc-frameworx/tbc-cli\" build",
    "all:clean": "rm -rf apps/*/dist packages/*/dist",
    "node_modules:clean": "rm -rf apps/*/node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "module": "index.ts",
  "type": "module"
}
