{
  "name": "tbc-frameworx-monorepo",
  "version": "0.1.0",
  "description": "Monorepo for TBC FRAMEWORX",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "record:build": "bun run --filter='@tbc-frameworx/tbc-record' build",
    "record-fs:build": "bun run --filter='@tbc-frameworx/tbc-record-fs' build",
    "record-sqlite:build": "bun run --filter='@tbc-frameworx/tbc-record-sqlite' build",
    "mint:build": "bun run --filter='@tbc-frameworx/tbc-mint' build",
    "mint-uuid:build": "bun run --filter='@tbc-frameworx/tbc-mint-uuid' build",
    "mint-tsid:build": "bun run --filter='@tbc-frameworx/tbc-mint-tsid' build",
    "dex:build": "bun run --filter='@tbc-frameworx/tbc-dex' build",
    "write:build": "bun run --filter='@tbc-frameworx/tbc-write' build",
    "system:build": "bun run --filter='@tbc-frameworx/tbc-system' build",
    "interface:build": "bun run --filter='@tbc-frameworx/tbc-interface' build",
    "memory:build": "bun run --filter='@tbc-frameworx/tbc-memory' build",
    "activity:build": "bun run --filter='@tbc-frameworx/tbc-activity' build",
    "gemini:build": "bun run --filter='@tbc-frameworx/tbc-gemini' build",
    "kilocode:build": "bun run --filter='@tbc-frameworx/tbc-kilocode' build",
    "goose:build": "bun run --filter='@tbc-frameworx/tbc-goose' build",
    "github-copilot:build": "bun run --filter='@tbc-frameworx/tbc-github-copilot' build",
    "cli:test": "bun test --filter='@tbc-frameworx/tbc-cli' --concurrency=1",
    "cli:build": "bun run --filter='@tbc-frameworx/tbc-cli' build",
    "cli:install": "bun run cli:build && cd apps/tbc-cli && bun link",
    "all:build": "bun run scripts/build-all.ts",
    "all:build-fresh": "bun run scripts/build-all.ts --clean",
    "all:build-dist": "bun run scripts/build-all.ts --clean --dist",
    "node_modules:clean": "shx rm -rf node_modules apps/*/node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "shx": "^0.4.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "module": "index.ts",
  "type": "module"
}